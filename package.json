{
  "private": true,
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @recruitflow/web dev",
    "dev:web:root": "next dev --turbopack --port ${PORT:-3001}",
    "dev:api": "pnpm --filter @recruitflow/api dev",
    "dev:stack": "pnpm --parallel --stream --filter @recruitflow/web --filter @recruitflow/api dev",
    "lint": "biome lint --changed --no-errors-on-unmatched .",
    "lint:all": "biome lint .",
    "format": "biome format --write --changed --no-errors-on-unmatched .",
    "format:all": "biome format --write .",
    "format:check": "biome format --changed --no-errors-on-unmatched .",
    "check": "biome check --changed --no-errors-on-unmatched .",
    "check:all": "biome check .",
    "check:staged": "biome check --staged --no-errors-on-unmatched .",
    "check:write": "biome check --write --changed --no-errors-on-unmatched .",
    "test:tasks-activity": "tsx apps/api/src/tasks/tasks.permissions.test.ts && tsx apps/api/src/notes/notes.permissions.test.ts && tsx lib/tasks/filters.test.ts",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json --pretty false && pnpm --filter @recruitflow/api check",
    "verify": "pnpm check && pnpm typecheck && pnpm build:web",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @recruitflow/web build",
    "build:web:root": "next build",
    "start": "pnpm start:web",
    "start:web": "pnpm --filter @recruitflow/web start",
    "start:web:root": "next start -p ${PORT:-3001}",
    "start:api": "pnpm --filter @recruitflow/api start",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@number-flow/react": "^0.6.0",
    "@recruitflow/config": "workspace:*",
    "@tailwindcss/postcss": "4.1.7",
    "@tanstack/react-query": "^5.99.0",
    "@types/node": "^22.15.18",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "@visx/curve": "4.0.1-alpha.0",
    "@visx/event": "4.0.1-alpha.0",
    "@visx/geo": "4.0.1-alpha.0",
    "@visx/gradient": "4.0.1-alpha.0",
    "@visx/grid": "4.0.1-alpha.0",
    "@visx/group": "4.0.1-alpha.0",
    "@visx/pattern": "4.0.1-alpha.0",
    "@visx/responsive": "4.0.1-alpha.0",
    "@visx/sankey": "4.0.1-alpha.0",
    "@visx/scale": "4.0.1-alpha.0",
    "@visx/shape": "4.0.1-alpha.0",
    "@visx/zoom": "4.0.1-alpha.0",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-geo": "^3.1.1",
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.18.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "motion": "^12.38.0",
    "next": "^15.6.0-canary.61",
    "postcss": "^8.5.3",
    "postgres": "^3.4.5",
    "radix-ui": "^1.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "sileo": "^0.1.5",
    "stripe": "^18.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4.1.7",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/d3-array": "^3.2.2",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "baseline-browser-mapping": "^2.10.20",
    "tsx": "^4.20.6"
  }
}
